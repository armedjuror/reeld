[Unit]
Description=ReelD FastAPI application
After=network.target

[Service]
User=reeld
Group=reeld
WorkingDirectory=/opt/reeld
EnvironmentFile=/opt/reeld/.env
ExecStart=/opt/reeld/venv/bin/uvicorn main:app \
    --host 127.0.0.1 \
    --port 8888 \
    --workers 2 \
    --log-level info
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

# Security hardening
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target